    "about": {
      "title": "Un poco",
      "subtitle": "Sobre mi",
      "content": {
        "hello": "¡Hola! soy Isa.",
        "image": {
          "src": "/portfolio/about_portrait.png",
          "alt": "Isabella Lizarralde Arias"
        },
        "description": {
          "paragraph1": "Me dedico a crear contenido de alta calidad, donde la estética y una edición que enganche van de la mano. Como Psicóloga, me encanta ir más allá de lo visual: busco tocar esos puntos de dolor y generar emociones reales que logren una conexión verdadera con quien está del otro lado de la pantalla.",
          "paragraph2": "",
          "paragraph3": ""
        },
        "whyWorkWithMeTitle": "¿Por qué trabajar conmigo?",
        "reasons": [
          {
            "title": "Cuidado en los detalles",
            "description": "Me apasiona entregar videos de alta calidad que se sientan profesionales, pero con esa esencia cercana que nos caracteriza."
          },
          {
            "title": "Confianza \"Bestie\"",
            "description": "Mi comunidad sabe que hablo desde la honestidad; por eso, cada colaboración se percibe como un consejo genuino entre amigas."
          },
          {
            "title": "Versatilidad",
            "description": "Me adapto con facilidad a cualquier reto creativo, logrando siempre que la esencia de tu marca sea la protagonista."
          }
        ],
        "experienceTitle": "Experiencia",
        "experience": {
          "brandsTrustedLabel": "marcas han confiado",
          "yearsCreatingLabel": "años creando contenido",
          "yearsUgcLabel": "años de experiencia UGC",
          "yearsCreatingValue": "+5",
          "yearsUgcValue": "+3"
        },
