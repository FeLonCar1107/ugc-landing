    "about": {
      "title": "A little",
      "subtitle": "About me",
      "content": {
        "hello": "Hello! I'm Isabella",
        "image": {
          "src": "/portfolio/about_portrait.png",
          "alt": "Isabella Lizarralde Arias"
        },
        "description": {
          "paragraph1": "I create high-quality content where aesthetics, strategy, and engaging editing work together. My goal is for every piece to look beautiful and drive real conversions.",
          "paragraph2": "As a Psychologist, I go beyond visuals: I identify your audience's pain points and turn them into messages that spark real emotions and authentic brand connection.",
          "paragraph3": "If you want a creator who blends creativity, closeness, and measurable results, I'm here to help your brand feel human, memorable, and irresistible."
        },
        "whyWorkWithMeTitle": "Why work with me?",
        "reasons": [
          {
            "title": "Attention to every detail",
            "description": "I love delivering polished, high-quality videos while keeping the warm tone that makes content feel truly relatable."
          },
          {
            "title": "\"Bestie\" trust",
            "description": "My audience knows I speak honestly, so every collaboration feels like a genuine recommendation between friends."
          },
          {
            "title": "Creative versatility",
            "description": "I adapt quickly to different challenges, formats, and goals so your brand essence is always front and center."
          }
        ],
