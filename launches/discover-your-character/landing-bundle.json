    "sections": [
      {
        "id": "sec_hero",
        "type": "hero",
        "order": 0,
        "content": {
          "headline": "Construye tu identidad y conviértete en la protagonista de tu contenido",
          "subheadline": "Deja de crear sin rumbo y empieza a construir contenido con intención y claridad.",
