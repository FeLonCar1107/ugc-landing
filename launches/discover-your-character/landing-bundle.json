        }
      },
      {
        "id": "sec_problem",
        "type": "problem",
        "order": 1,
        "content": {
          "title": "Cuando publicas sin identidad clara, el esfuerzo no se convierte en resultados",
          "bullets": [
            "No tengo seguidores suficientes",
            "No sé qué contenido hacer",
            "Siento que ya todo está saturado",
            "No sé si esto realmente funcione para mí"
          ]
        }
      },
      {
        "id": "sec_solution",
        "type": "solution",
        "order": 2,
        "content": {
