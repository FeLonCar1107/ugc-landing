            "Romper creencias que te frenan",
            "Definir identidad visual con intención",
            "Estructuras de contenido + retención",
            "Enfoque de monetización realista"
          ]
        }
      },
      {
        "id": "sec_proof",
        "type": "social_proof",
        "order": 3,
        "content": {
