            "Timeline 2022–2025"
          ]
        }
      },
      {
        "id": "sec_offer",
        "type": "offer_stack",
        "order": 4,
        "content": {
          "bullets": [
            "Plantilla estructura de contenido",
            "Banco de ideas de contenido",
            "Moodboard identidad visual",
            "Rutina simple de creación"
          ],
          "checkoutUrl": "env:NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_CHECKOUT_URL",
          "priceUsd": "env:NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_PRICE_USD"
        }
      },
      {
        "id": "sec_faq",
        "type": "faq",
        "order": 5,
        "content": {
          "intro": "Respuestas rápidas antes de entrar al checkout."
        }
      },
      {
        "id": "sec_close",
        "type": "cta_band",
        "order": 6,
        "content": {
