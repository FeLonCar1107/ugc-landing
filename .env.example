# Copy to `.env` or `.env.local` and fill values.
# Convención por slug: kebab-case → MAYÚSCULAS con guión bajo (ej. complete-saga → COMPLETE_SAGA).

NODE_ENV=development
NEXT_PUBLIC_BASE_URL=https://www.example.com

# --- Servicios (no específicos de ebook) ---
RESEND_API_KEY=
INSTAGRAM_ACCESS_TOKEN=
# CRON_SECRET=
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_DATABASE_URL=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# --- GA4 (landings ebook) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GA_DEBUG=true

# --- Ebooks: global ---
NEXT_PUBLIC_LAUNCH_HERO_VISUAL=mockup
# Struck-through reference price for every bonus row in all landings (e.g. 3.9).
NEXT_PUBLIC_LAUNCH_BONUS_ANCHOR_PRICE_USD=3.9
# Optional fallback when a slug omits EBOOK_ANCHOR_PRICE_USD below:
# NEXT_PUBLIC_LAUNCH_EBOOK_ANCHOR_PRICE_USD=

# --- discover-your-character ---
NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_CHECKOUT_URL=
NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_PRICE_USD=
# Struck-through ebook reference price in value stack (per volume)
NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_EBOOK_ANCHOR_PRICE_USD=
NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_TIME_TO_RESULT=
NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_SOCIAL_COUNT=
NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_HERO_VISUAL=mockup
NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_OFFER_PHASE_LABEL=
# Calendar day; ends 23:59:59 Colombia (es) / US Eastern (en). Example: 2026-06-15
NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_BONUS_BUNDLE_DEADLINE_ISO=2026-06-15

# --- catch-the-attention ---
NEXT_PUBLIC_LAUNCH_CATCH_THE_ATTENTION_CHECKOUT_URL=
NEXT_PUBLIC_LAUNCH_CATCH_THE_ATTENTION_PRICE_USD=
NEXT_PUBLIC_LAUNCH_CATCH_THE_ATTENTION_EBOOK_ANCHOR_PRICE_USD=
NEXT_PUBLIC_LAUNCH_CATCH_THE_ATTENTION_TIME_TO_RESULT=
NEXT_PUBLIC_LAUNCH_CATCH_THE_ATTENTION_SOCIAL_COUNT=
NEXT_PUBLIC_LAUNCH_CATCH_THE_ATTENTION_HERO_VISUAL=mockup
NEXT_PUBLIC_LAUNCH_CATCH_THE_ATTENTION_OFFER_PHASE_LABEL=
NEXT_PUBLIC_LAUNCH_CATCH_THE_ATTENTION_BONUS_BUNDLE_DEADLINE_ISO=

# --- magnetic-creator ---
NEXT_PUBLIC_LAUNCH_MAGNETIC_CREATOR_CHECKOUT_URL=
NEXT_PUBLIC_LAUNCH_MAGNETIC_CREATOR_PRICE_USD=
NEXT_PUBLIC_LAUNCH_MAGNETIC_CREATOR_EBOOK_ANCHOR_PRICE_USD=
NEXT_PUBLIC_LAUNCH_MAGNETIC_CREATOR_TIME_TO_RESULT=
NEXT_PUBLIC_LAUNCH_MAGNETIC_CREATOR_SOCIAL_COUNT=
NEXT_PUBLIC_LAUNCH_MAGNETIC_CREATOR_HERO_VISUAL=mockup
NEXT_PUBLIC_LAUNCH_MAGNETIC_CREATOR_OFFER_PHASE_LABEL=
NEXT_PUBLIC_LAUNCH_MAGNETIC_CREATOR_BONUS_BUNDLE_DEADLINE_ISO=

# --- complete-saga (bundle) ---
NEXT_PUBLIC_LAUNCH_COMPLETE_SAGA_CHECKOUT_URL=
NEXT_PUBLIC_LAUNCH_COMPLETE_SAGA_PRICE_USD=
NEXT_PUBLIC_LAUNCH_COMPLETE_SAGA_TIME_TO_RESULT=
NEXT_PUBLIC_LAUNCH_COMPLETE_SAGA_SOCIAL_COUNT=
NEXT_PUBLIC_LAUNCH_COMPLETE_SAGA_HERO_VISUAL=portrait
NEXT_PUBLIC_LAUNCH_COMPLETE_SAGA_OFFER_PHASE_LABEL=
NEXT_PUBLIC_LAUNCH_COMPLETE_SAGA_BONUS_BUNDLE_DEADLINE_ISO=
