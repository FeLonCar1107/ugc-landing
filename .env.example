# Copy to `.env.local`. For each slug in ALLOWED_LANDING_SLUGS, add:
# NEXT_PUBLIC_LAUNCH_<SLUG_UPPER_SNAKE>_CHECKOUT_URL
# NEXT_PUBLIC_LAUNCH_<SLUG_UPPER_SNAKE>_PRICE_USD
# NEXT_PUBLIC_LAUNCH_<SLUG_UPPER_SNAKE>_TIME_TO_RESULT
#
# Optional: label shown near offer urgency (editorial, not fake inventory)
# NEXT_PUBLIC_LAUNCH_<SLUG_UPPER_SNAKE>_OFFER_PHASE_LABEL=
#
# Optional: ISO-8601 instant — shows localized deadline line next to bonuses (ethical deadline)
# NEXT_PUBLIC_LAUNCH_<SLUG_UPPER_SNAKE>_BONUS_BUNDLE_DEADLINE_ISO=2026-06-15T23:59:59.000Z
#
# GA4 Measurement ID (public). Landing fires custom events landing_view + cta_checkout_click.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
#
# First hero image (conversion A/B): unset or anything other than mockup = portrait (hero_done.png); `mockup` = ebook mockup (offer_ebook_mockup.png)
# NEXT_PUBLIC_LAUNCH_<SLUG_UPPER_SNAKE>_HERO_VISUAL=mockup

NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_CHECKOUT_URL=
NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_PRICE_USD=
NEXT_PUBLIC_LAUNCH_DISCOVER_YOUR_CHARACTER_TIME_TO_RESULT=

NEXT_PUBLIC_GA_MEASUREMENT_ID=
